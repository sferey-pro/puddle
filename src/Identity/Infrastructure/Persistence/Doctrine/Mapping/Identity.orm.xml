<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Identity\Domain\Model\Identity" table="identity_profiles">
        <id name="id" type="identity_id" />

        <field name="accountId" type="account_id" column="account_id" unique="true" />
        <field name="email" type="email" column="email" />
        <field name="displayName" type="string" column="display_name" length="100" />
        <field name="firstName" type="string" column="first_name" nullable="true" length="50" />
        <field name="lastName" type="string" column="last_name" nullable="true" length="50" />
        <field name="avatarUrl" type="string" column="avatar_url" nullable="true" length="255" />
        <field name="locale" type="string" column="locale" length="5" />
        <field name="timezone" type="string" column="timezone" length="50" />
        <field name="phoneNumber" type="string" column="phone_number" nullable="true" length="20" />
        <field name="phoneNumberVerified" type="boolean" column="phone_number_verified" />
        <field name="createdAt" type="datetime_immutable" column="created_at" />
        <field name="updatedAt" type="datetime_immutable" column="updated_at" />

        <indexes>
            <index columns="account_id" />
            <index columns="email" />
        </indexes>
    </entity>
</doctrine-mapping>
