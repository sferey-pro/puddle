<div {{ attributes }}>
    {% if errorMessage %}
        <twig:Alert type="warning" :message="errorMessage" format="important" />
    {% endif %}

    {{ form_start(form, {
        attr: {
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'save',
            novalidate: true,
            class: 'card card-md',
        },
    }) }}
        {{ form_errors(form) }}
        <div class="card-body">
            <h2 class="card-title text-center mb-4">Create new account</h2>
            {{ form_row(form.identifier, {
                'label': 'Email address or Phone number',
                'attr': {'placeholder': 'example@email.com ou +33612345678'
            }}) }}

            <twig:Alert type="notice" format="important" :dismissible="false" >
                Après votre inscription, vous recevrez un message avec vos informations de connexion sécurisées.
            </twig:Alert>

            <div class="form-footer">
                <button type="submit" class="btn btn-primary w-100 {{ this.hasValidationErrors ? 'disabled' : '' }}">Create new account</button>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form) }}
</div>
