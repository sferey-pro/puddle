<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Authentication\Domain\Model\Session" table="auth_sessions">
        <id name="id" type="session_id" />

        <field name="accountId" type="account_id" column="account_id" />
        <field name="token" type="session_token" column="token" unique="true" />
        <field name="ipAddress" type="string" column="ip_address" length="45" />
        <field name="userAgent" type="string" column="user_agent" length="255" />
        <field name="deviceFingerprint" type="device_fingerprint" column="device_fingerprint" nullable="true" />
        <field name="createdAt" type="datetime_immutable" column="created_at" />
        <field name="lastActivityAt" type="datetime_immutable" column="last_activity_at" />
        <field name="expiresAt" type="datetime_immutable" column="expires_at" />
        <field name="is2FAVerified" type="boolean" column="is_2fa_verified" />
        <field name="isActive" type="boolean" column="is_active" />
        <field name="invalidationReason" type="string" column="invalidation_reason" nullable="true" length="50" />

        <indexes>
            <index columns="account_id,is_active" />
            <index columns="token" />
            <index columns="expires_at" />
            <index columns="device_fingerprint" />
        </indexes>
    </entity>
</doctrine-mapping>
