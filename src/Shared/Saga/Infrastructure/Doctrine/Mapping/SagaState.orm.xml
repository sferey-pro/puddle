<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Shared\Saga\Domain\SagaState" table="saga_state">

        <embedded name="id" class="App\Shared\Saga\Domain\ValueObject\SagaStateId"  use-column-prefix="false" />

        <field name="sagaType" type="string" column="saga_type" length="100" nullable="false" />
        <field name="status" type="string" enum-type="App\Shared\Saga\Domain\Enum\SagaStatus" />
        <field name="currentStep" type="integer" column="current_step" nullable="false" />
        <field name="payload" type="json" column="payload" nullable="false" />
        <field name="completedAt" type="datetime_immutable" column="completed_at" nullable="true" />
        <field name="failureReason" type="text" column="failure_reason" nullable="true" />

        <field name="createdAt" type="datetime" column="created_at">
            <gedmo:timestampable on="create"/>
        </field>

        <field name="updatedAt" type="datetime" column="updated_at">
            <gedmo:timestampable on="update"/>
        </field>
    </entity>
</doctrine-mapping>
